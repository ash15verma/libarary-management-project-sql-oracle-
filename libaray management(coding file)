--Libary management project of oracle(sql):
--1st table is Branch
--branch_id	manager_id	branch_address	contact_no(list of columns in a table):
--first step:we need to create a test table to get the data from csv to sql in a char datatypes.
CREATE TABLE BRANCH_TEST(
branch_id CHAR(15),
manager_id  CHAR(20),
branch_address CHAR(20),
contact_no CHAR(15));

select *from branch_test

--2nd stpe:later, need to create a ctl file, where, data needs to be transfered from csv to ctl file.
--3rd step:-after transferring data into ctl file, we need to create a schema of branch table with real datatypes.
CREATE TABLE BRANCH(
BRANCH_ID NUMBER(15) PRIMARY KEY,
MANAGER_ID  VARCHAR2(20),
BRANCH_ADDRESS VARCHAR2(20),
CONTACT_NO VARCHAR2(15));

SELECT *FROM BRANCH
desc branch;
--4th step:-create a cmd file to transferred data from ctl file to a test table.
--5th step:-use cursor to tranferred the records from test table to the real table.

SET SERVEROUTPUT ON
DECLARE
CURSOR C1 IS
SELECT branch_id, manager_id, branch_address, contact_no
from BRANCH_TEST;
BEGIN
FOR REC IN C1 LOOP 
INSERT INTO BRANCH
(branch_id,manager_id,branch_address, contact_no)
values
(rec.branch_id,rec.manager_id,rec.branch_address, rec.contact_no);
end loop;
commit;
end;
