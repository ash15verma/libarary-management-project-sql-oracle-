----------------------------------------------------RETURN STATUS----------------------------------------------------------------------------
create table return_status(
return_id varchar2(100),
issued_id varchar2(100),
return_book_name varchar2(100),
return_date date,
return_book_isbn varchar2(50));

--to apply foreign key here which is a primary key in books table.
alter table return_status
add constraint return_status_isbn
foreign key(isbn) references book(isbn);

--error--to remove any not null values from a column
--while, I was facing a issue to established a link between pk and fk.
--so, in that case, I have come across, that, there are some unwanted values exists in a null values in fk key column, but could'nt recongsied what is the real issue.
--so I replaced, null values with the unwanted values.

--syntax to resolving this type of error--
UPDATE return_status
SET isbn = NULL
WHERE isbn IS NOT NULL
AND isbn NOT IN (SELECT isbn FROM book);
